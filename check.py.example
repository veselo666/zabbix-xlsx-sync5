#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import sys
import requests
import urllib3

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

ZABBIX_URL = "https://127.0.0.1/api_jsonrpc.php"
ZABBIX_USER = "login"
ZABBIX_PASSWORD = "pass"

TOKEN = None


def api(method, params=None):
    global TOKEN

    request = {
        "jsonrpc": "2.0",
        "method": method,
        "params": {} if params is None else params,
        "id": 1,
    }

    if TOKEN:
        request["auth"] = TOKEN

    response = requests.post(
        ZABBIX_URL,
        json=request,
        verify=False,
        timeout=30,
    )

    data = response.json()

    if "error" in data:
        raise Exception(data["error"])

    return data["result"]


def item_has_data(item):
    # Если lastclock пустой или 0 — latestdata нет
    return item.get("lastclock") not in ("0", "", None)


if len(sys.argv) < 2:
    print(f"Использование: {sys.argv[0]} host1 host2 host3")
    sys.exit(2)


try:
    # Логинимся в Zabbix
    TOKEN = api("user.login", {
        "user": ZABBIX_USER,
        "password": ZABBIX_PASSWORD,
    })

    exit_code = 0

    for host_name in sys.argv[1:]:

        # Ищем хост по technical name
        hosts = api("host.get", {
            "output": ["hostid", "host", "name"],
            "filter": {
                "host": [host_name],
            },
        })

        # Если не нашли — пробуем искать по visible name
        if not hosts:
            hosts = api("host.get", {
                "output": ["hostid", "host", "name"],
                "filter": {
                    "name": [host_name],
                },
            })

        if not hosts:
            print(f"\n[ERROR] Хост не найден: {host_name}")
            exit_code = 2
            continue

        host = hosts[0]

        print()
        print(f"Хост: {host['host']} / {host.get('name') or host['host']}")
        print("=" * 80)

        # Забираем все унаследованные items с хоста
        items = api("item.get", {
            "output": [
                "itemid",
                "name",
                "key_",
                "status",
                "state",
                "lastclock",
                "templateid",
            ],
            "hostids": [host["hostid"]],
            "inherited": True,
        })

        # Собираем ID родительских items из шаблонов
        parent_item_ids = []

        for item in items:
            if item.get("templateid") not in ("0", "", None):
                parent_item_ids.append(item["templateid"])

        parent_item_ids = list(set(parent_item_ids))

        if not parent_item_ids:
            print("Нет items от шаблонов")
            continue

        # Получаем родительские items из шаблонов
        parent_items = api("item.get", {
            "output": ["itemid", "hostid"],
            "itemids": parent_item_ids,
        })

        # Делаем словарь:
        # parent itemid -> templateid
        parent_to_template = {}

        for parent in parent_items:
            parent_to_template[parent["itemid"]] = parent["hostid"]

        # Собираем ID шаблонов
        template_ids = []

        for parent in parent_items:
            template_ids.append(parent["hostid"])

        template_ids = list(set(template_ids))

        # Получаем имена шаблонов
        templates = api("template.get", {
            "output": ["templateid", "host", "name"],
            "templateids": template_ids,
        })

        # Делаем словарь:
        # templateid -> template name
        template_names = {}

        for template in templates:
            template_names[template["templateid"]] = template.get("name") or template.get("host")

        # Готовим отчёт
        report = {}

        for item in items:
            parent_item_id = item.get("templateid")

            if parent_item_id not in parent_to_template:
                continue

            template_id = parent_to_template[parent_item_id]
            template_name = template_names.get(template_id, f"templateid:{template_id}")

            if template_name not in report:
                report[template_name] = {
                    "total": 0,
                    "disabled": 0,
                    "nodata": [],
                }

            report[template_name]["total"] += 1

            # status 1 — item выключен
            if item["status"] == "1":
                report[template_name]["disabled"] += 1
                continue

            # status 0 — item включен
            # Если включен, но latestdata нет — добавляем в список проблем
            if item["status"] == "0" and not item_has_data(item):
                report[template_name]["nodata"].append(item)

        # Печатаем отчёт по шаблонам
        for template_name in sorted(report):
            data = report[template_name]

            print()
            print(template_name)
            print("-" * len(template_name))
            print(f"Всего items: {data['total']}")
            print(f"items выключены: {data['disabled']}")
            print(f"items без данных: {len(data['nodata'])}")

            if data["nodata"]:
                exit_code = 1

                print()
                print("Список items без данных:")

                for item in data["nodata"]:
                    print(
                        f"  - {item['name']} | "
                        f"key={item['key_']} | "
                        f"itemid={item['itemid']} | "
                        f"lastclock={item.get('lastclock')} | "
                        f"state={item.get('state')}"
                    )

    # Выходим из API
    api("user.logout", [])

    sys.exit(exit_code)

except Exception as e:
    print(f"[ERROR] {e}")
    sys.exit(2)
